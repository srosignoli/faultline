FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o controller ./cmd/controller

FROM alpine:latest
RUN apk add --no-cache ca-certificates \
    && addgroup -g 10001 -S faultline \
    && adduser -u 10001 -S faultline -G faultline
COPY --from=builder /app/controller /usr/local/bin/controller
USER faultline
EXPOSE 8080
ENTRYPOINT ["controller"]
